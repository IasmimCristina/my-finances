<section class="space-y-8">
  <div>
    <h1 class="text-3xl font-bold text-gray-900">
      Boas vindas, <%= Current.user.name %>
    </h1>
    <p class="text-gray-600 mt-2">
      <% if Current.user.admin? %>
        Você está acessando como <span class="font-bold text-red-900">Administrador(a)</span>
      <% else %>
        Você está acessando como <span class="font-bold text-red-900">Membro</span>
      <% end %>
    </p>
  </div>

  <% if Current.user.admin? %>
    <%= render "home/dashboard/admin" %>
  <% else %>
    <%= render "home/dashboard/member" %>
  <% end %>
</section>
