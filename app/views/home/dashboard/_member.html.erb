<div class="grid md:grid-cols-3 gap-6">
  <div class="bg-red-50 p-6 rounded-lg border-l-4 border-red-900">
    <h3 class="text-sm font-semibold text-gray-600 uppercase">Saldo do Mês</h3>
    <p class="text-3xl font-bold text-red-900 mt-2">-</p>
    <p class="text-xs text-gray-600 mt-2">Atualizado hoje</p>
  </div>

  <div class="bg-green-50 p-6 rounded-lg border-l-4 border-green-600">
    <h3 class="text-sm font-semibold text-gray-600 uppercase">Total de Receitas</h3>
    <p class="text-3xl font-bold text-green-600 mt-2">-</p>
    <p class="text-xs text-gray-600 mt-2">Este mês</p>
  </div>

  <div class="bg-yellow-50 p-6 rounded-lg border-l-4 border-yellow-600">
    <h3 class="text-sm font-semibold text-gray-600 uppercase">Total de Despesas</h3>
    <p class="text-3xl font-bold text-yellow-600 mt-2">-</p>
    <p class="text-xs text-gray-600 mt-2">Este mês</p>
  </div>
</div>

<div class="mt-8 bg-gray-50 p-6 rounded-lg border border-gray-200">
  <h3 class="text-lg font-bold text-gray-900 mb-4">Ações Rápidas</h3>
  <div class="space-y-3">
    <%= link_to "Nova Transação", "#", class: "block p-3 bg-white border border-gray-300 rounded hover:bg-red-50 hover:border-red-300 transition" %>
    <%= link_to "Ver Transações", "#", class: "block p-3 bg-white border border-gray-300 rounded hover:bg-red-50 hover:border-red-300 transition" %>
    <%= link_to "Orçamento", "#", class: "block p-3 bg-white border border-gray-300 rounded hover:bg-red-50 hover:border-red-300 transition" %>
  </div>
</div>
