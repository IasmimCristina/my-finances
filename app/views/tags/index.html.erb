<div class="max-w-4xl mx-auto py-12">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Tags</h1>
    <% if @can_create %>
      <%= link_to "Nova Tag", new_tag_path, class: "px-4 py-2 bg-red-900 text-white rounded-lg hover:bg-red-800 transition font-medium" %>
    <% end %>
  </div>

  <% if @tags.any? %>
    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Nome</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Cor</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Descrição</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Transações</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @tags.each do |tag| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 text-sm text-gray-900 font-medium">
                <%= link_to tag.name, tag_path(tag), class: "text-red-900 hover:underline" %>
              </td>
              <td class="px-6 py-4 text-sm">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded border border-gray-300" style="background-color: <%= tag.color %>"></div>
                  <code class="text-xs text-gray-500"><%= tag.color %></code>
                </div>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">
                <%= truncate(tag.description, length: 40) %>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                  <%= tag.transactions.count %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm space-x-2">
                <% if policy(tag).update? %>
                  <%= link_to "Editar", edit_tag_path(tag), class: "text-red-900 hover:underline" %>
                <% end %>
                <% if policy(tag).destroy? %>
                  <%= link_to "Deletar", tag_path(tag), method: :delete, data: { confirm: "Tem certeza?" }, class: "text-red-600 hover:underline" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-gray-50 rounded-lg p-8 text-center">
      <p class="text-gray-600 mb-4">Nenhuma tag criada ainda.</p>
      <% if @can_create %>
        <%= link_to "Criar Primeira Tag", new_tag_path, class: "text-red-900 hover:underline font-medium" %>
      <% end %>
    </div>
  <% end %>
</div>
