<div class="max-w-2xl mx-auto py-12">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900"><%= @user.name %></h1>
    <div class="flex gap-2">
      <% if policy(@user).update? %>
        <%= link_to "Editar", edit_user_path(@user), class: "px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition" %>
      <% end %>
      <% if policy(@user).destroy? %>
        <%= link_to "Deletar", user_path(@user), method: :delete, data: { confirm: "Tem certeza?" }, class: "px-4 py-2 bg-red-100 text-red-900 rounded-lg hover:bg-red-200 transition border border-red-300" %>
      <% end %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6 space-y-6">
    <!-- Email -->
    <div>
      <label class="text-sm font-medium text-gray-500">Email</label>
      <p class="mt-2 text-gray-900"><%= @user.email %></p>
    </div>

    <!-- Role -->
    <div>
      <label class="text-sm font-medium text-gray-500">Role</label>
      <div class="mt-2">
        <% if @user.admin? %>
          <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-purple-100 text-purple-800">
            Admin
          </span>
        <% else %>
          <span class="inline-flex items-center px-4 py-2 rounded-lg text-sm font-medium bg-blue-100 text-blue-800">
            Member
          </span>
        <% end %>
      </div>
    </div>

    <!-- Criado em -->
    <div class="text-xs text-gray-500 border-t pt-4">
      Criado <%= time_ago_in_words(@user.created_at) %> atrás
    </div>
  </div>

  <div class="mt-8">
    <%= link_to "← Voltar", users_path, class: "text-red-900 hover:underline font-medium" %>
  </div>
</div>
