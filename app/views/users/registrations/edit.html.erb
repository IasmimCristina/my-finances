<div class="max-w-2xl mx-auto py-12">
  <h2 class="text-3xl font-bold text-gray-900 mb-8">Editar Perfil</h2>

  <%= render "users/shared/error_messages", resource: resource %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, local: true }) do |f| %>
    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 space-y-4 mb-8">
      <div>
        <%= f.label :name, "Nome Completo", class: "block text-sm font-medium text-gray-900 mb-2" %>
        <%= f.text_field :name, autofocus: true, class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-900 focus:border-transparent" %>
      </div>

      <div>
        <%= f.label :email, "Email", class: "block text-sm font-medium text-gray-900 mb-2" %>
        <%= f.email_field :email, autocomplete: "email", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-900 focus:border-transparent" %>
      </div>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <div class="bg-yellow-50 border-l-4 border-yellow-600 p-4 rounded text-sm text-yellow-800">
          Aguardando confirmação para: <%= resource.unconfirmed_email %>
        </div>
      <% end %>
    </div>

    <div class="bg-gray-50 p-6 rounded-lg border border-gray-200 space-y-4 mb-8">
      <h3 class="text-lg font-bold text-gray-900">Alterar Senha</h3>

      <div>
        <%= f.label :password, "Nova Senha", class: "block text-sm font-medium text-gray-900 mb-2" %>
        <p class="text-xs text-gray-600 mb-1">Deixar em branco se não quiser alterar</p>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-600 mb-1">Mínimo <%= @minimum_password_length %> caracteres</p>
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-900 focus:border-transparent" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmar Senha", class: "block text-sm font-medium text-gray-900 mb-2" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-900 focus:border-transparent" %>
      </div>

      <div>
        <%= f.label :current_password, "Senha Atual", class: "block text-sm font-medium text-gray-900 mb-2" %>
        <p class="text-xs text-gray-600 mb-1">Obrigatório para confirmar as alterações</p>
        <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-900 focus:border-transparent" %>
      </div>
    </div>

    <div class="flex gap-4">
      <%= f.submit "Salvar Alterações", class: "px-6 py-2 bg-red-900 text-white rounded-lg hover:bg-red-800 transition font-medium" %>
      <%= link_to "Voltar", :back, class: "px-6 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition" %>
    </div>
  <% end %>

  <div class="mt-12 pt-8 border-t border-gray-200">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Deletar Conta</h3>
    <p class="text-sm text-gray-600 mb-4">
      Esta ação é irreversível. Todos os seus dados serão deletados permanentemente.
    </p>
    <%= button_to "Deletar Minha Conta", registration_path(resource_name), data: { turbo_confirm: "Tem certeza que deseja deletar sua conta?" }, method: :delete, class: "px-6 py-2 bg-red-100 text-red-900 rounded-lg hover:bg-red-200 transition font-medium border border-red-300" %>
  </div>
</div>
